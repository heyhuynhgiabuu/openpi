# ── Pi / Beads agent artifacts ─────────────────────────────────────────────
.beads/
.bv/
.pi/

# ── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ── Build outputs ──────────────────────────────────────────────────────────
out/                    # electron-vite compiled output
dist/
dist-electron/
release/                # electron-builder packaged installers
dist-artifacts/         # CI release artifact download directory
coverage/
*.tsbuildinfo

# ── electron-builder generated files ──────────────────────────────────────
builder-debug.yml       # debug config generated by electron-builder
builder-effective-config.yaml

# ── Test / browser automation ──────────────────────────────────────────────
playwright-report/
test-results/

# ── Runtime data ───────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ── Code-signing certificates (never commit) ───────────────────────────────
*.pem
*.p12
*.p8
*.pfx

# ── OS metadata ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Local environment ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
